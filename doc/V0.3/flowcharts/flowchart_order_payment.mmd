    style CartNoship fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrPointsRule fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrOff fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrStock fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrDelivery fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrExpire fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrBeansNotSupport fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrBeansAll fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrExpireCombo fill:#fff3e0,stroke:#ff9800,color:#333
    style ErrComboNotSupport fill:#fff3e0,stroke:#ff9800,color:#333
    style BeansPartial fill:#fff9f5,stroke:#ff6034,color:#333
    style ErrCancelled fill:#fff3e0,stroke:#ff9800,color:#333
